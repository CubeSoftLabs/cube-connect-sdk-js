{
  "name": "@cubesoftware/cube-connect-sdk-js",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for CubeConnect WhatsApp Business Platform",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cubeconnect",
    "cubesoftware",
    "whatsapp",
    "whatsapp-business-api",
    "saudi-arabia"
  ],
  "author": "CubeConnect <dev@cubeconnect.io> (https://cubeconnect.io)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CubeSoftLabs/cube-connect-sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/CubeSoftLabs/cube-connect-sdk-js/issues"
  },
  "homepage": "https://docs.cubeconnect.io/sdks/javascript",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
